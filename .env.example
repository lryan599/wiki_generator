OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
TAVILY_API_KEY=

MAX_STRUCTURED_OUTPUT_RETRIES=3
ALLOW_CLARIFICATION=false
MAX_CONCURRENT_RESEARCH_UNITS=5
SEARCH_API=none

KNOWLEDGE_BASE_URL=
WORKSPACE_ID=
KNOWLEDGE_BASE_QUERY_TIMEOUT_SECONDS=120
KNOWLEDGE_BASE_WINDOW_TIMEOUT_SECONDS=120
COMPRESSION_IMAGE_LIMIT=4
COMPRESSION_IMAGE_MAX_BYTES=8000000

SAVE_WIKI_MARKDOWN=true
WIKI_OUTPUT_DIR=wiki_outputs
WIKI_OUTPUT_FILENAME=

SUMMARIZATION_TIMEOUT_SECONDS=60
SUMMARIZATION_MODEL=openai:gpt-4.1-mini
SUMMARIZATION_MODEL_MAX_TOKENS=8192
MAX_CONTENT_LENGTH=50000
RESEARCH_MODEL=openai:gpt-4.1
RESEARCH_MODEL_MAX_TOKENS=10000
COMPRESSION_MODEL=openai:gpt-4.1
COMPRESSION_MODEL_MAX_TOKENS=8192
FINAL_REPORT_MODEL=openai:gpt-4.1
FINAL_REPORT_MODEL_MAX_TOKENS=10000
MAX_RESEARCHER_ITERATIONS=6
MAX_REACT_TOOL_CALLS=10
MCP_CONFIG=
MCP_PROMPT=

LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
LANGSMITH_TRACING=

# Only necessary for Open Agent Platform
SUPABASE_KEY=
SUPABASE_URL=
# Should be set to true for a production deployment on Open Agent Platform. Should be set to false otherwise, such as for local development.
GET_API_KEYS_FROM_CONFIG=false
